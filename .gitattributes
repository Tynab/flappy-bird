# Chuẩn hoá EOL cho tất cả file text.
* text=auto eol=lf

# Godot scene và resource — xử lý như text.
*.tscn text
*.tres text
*.godot text

# GDScript — xử lý như text.
*.gd text

# File import Godot là text, giữ LF để tránh dirty repo sau khi clone.
*.import text eol=lf

# Asset nhị phân và output build: không chuẩn hoá EOL.
*.png -text
*.jpg -text
*.pck -text
*.wasm -text